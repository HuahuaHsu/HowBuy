@model ISpanShop.MVC.Models.Promotions.PromotionIndexVm

@{
    Layout = "~/Views/Shared/_SneatLayout.cshtml";
    ViewData["Title"] = "促銷活動管理";
}

<style>
    .font-noto { font-family: 'Public Sans', 'Noto Sans TC', sans-serif; }
    .stat-card { border-radius: 12px; border: none; }
    .stat-icon { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
    .status-tabs .nav-link { color: #64748b; font-size: .875rem; padding: .4rem .9rem; border-radius: 6px; }
    .status-tabs .nav-link.active { color: #fff; background: #3182ce; }
    .table > :not(caption) > * > * { padding: .85rem .75rem; }
    .promo-name { font-weight: 600; color: #1e2d3d; font-size: .938rem; }
    .promo-desc { font-size: .813rem; color: #a1acb8; }
    .pending-row { border-left: 3px solid #f59e0b; }
    .act-icon {
        width: 30px; height: 30px; display: inline-flex; align-items: center; justify-content: center;
        border-radius: .375rem; border: 1px solid #e2e8f0; background: #fff; color: #64748b;
        cursor: pointer; transition: all .2s; text-decoration: none;
    }
    .act-icon:hover { background: #f8fafc; color: #3182ce; border-color: #cbd5e1; }
    .act-icon.danger:hover { background: #fff5f5; color: #ea5455; border-color: #feb2b2; }
    /* 統計卡片可點擊 */
    a.stat-card { text-decoration: none; color: inherit; display: block; transition: transform .15s, box-shadow .15s; }
    a.stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 22px rgba(0,0,0,.13) !important; cursor: pointer; }
    a.stat-card.stat-active { border: 2px solid #3182ce !important; background: #eff6ff; }
    /* Badge 放大 */
    .badge { font-size: .813rem !important; padding: 5px 10px !important; white-space: nowrap; }
</style>

<div class="container-fluid py-4 font-noto">

    @* 頁首 *@
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="color:#1e2d3d; letter-spacing:-.02em;">
                <i class="bx bx-purchase-tag-alt me-2" style="color:#3182ce;"></i>促銷活動管理
            </h2>
            <p class="mb-0 text-muted" style="font-size:.875rem;">審核賣家申請的促銷活動，或直接建立平台活動</p>
        </div>
    </div>

    @* TempData 訊息 *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bx bx-error-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* 統計卡片（可點擊篩選）*@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <a href="@Url.Action("Index", new { status = "pending", keyword = Model.Keyword, type = Model.TypeFilter })"
               class="card stat-card shadow-sm h-100 @(Model.StatusFilter == "pending" ? "stat-active" : "")">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="stat-icon" style="background:#fff3cd;">
                        <i class="bx bx-time-five" style="color:#f59e0b;"></i>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size:.8rem;">待審核</div>
                        <h4 class="mb-0 fw-bold" style="color:#1e2d3d;">@Model.PendingCount</h4>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a href="@Url.Action("Index", new { status = "active", keyword = Model.Keyword, type = Model.TypeFilter })"
               class="card stat-card shadow-sm h-100 @(Model.StatusFilter == "active" ? "stat-active" : "")">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="stat-icon" style="background:#d1fae5;">
                        <i class="bx bx-play-circle" style="color:#10b981;"></i>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size:.8rem;">進行中</div>
                        <h4 class="mb-0 fw-bold" style="color:#1e2d3d;">@Model.ActiveCount</h4>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a href="@Url.Action("Index", new { status = "upcoming", keyword = Model.Keyword, type = Model.TypeFilter })"
               class="card stat-card shadow-sm h-100 @(Model.StatusFilter == "upcoming" ? "stat-active" : "")">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="stat-icon" style="background:#dbeafe;">
                        <i class="bx bx-calendar-check" style="color:#3b82f6;"></i>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size:.8rem;">即將開始</div>
                        <h4 class="mb-0 fw-bold" style="color:#1e2d3d;">@Model.UpcomingCount</h4>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a href="@Url.Action("Index", new { status = "ended", keyword = Model.Keyword, type = Model.TypeFilter })"
               class="card stat-card shadow-sm h-100 @(Model.StatusFilter == "ended" ? "stat-active" : "")">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="stat-icon" style="background:#f1f5f9;">
                        <i class="bx bx-check-double" style="color:#94a3b8;"></i>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size:.8rem;">已結束</div>
                        <h4 class="mb-0 fw-bold" style="color:#1e2d3d;">@Model.EndedCount</h4>
                    </div>
                </div>
            </a>
        </div>
    </div>

    @* 篩選列 *@
    <div class="card shadow-sm mb-0" style="border-radius:12px 12px 0 0; border-bottom:none;">
        <div class="card-body py-3">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                @* 狀態 Tabs *@
                <ul class="nav status-tabs gap-1 mb-0">
                    @{
                        var tabs = new[] {
                            ("all","全部", ""),
                            ("pending","待審核",""),
                            ("active","進行中",""),
                            ("upcoming","即將開始",""),
                            ("rejected","已拒絕",""),
                            ("ended","已結束",""),
                        };
                    }
                    @foreach (var (val, label, icon) in tabs)
                    {
                        var isActive = (Model.StatusFilter ?? "all") == val;
                        <li class="nav-item">
                            <a href="@Url.Action("Index", new { keyword = Model.Keyword, status = val == "all" ? null : val, type = Model.TypeFilter })"
                               class="nav-link @(isActive ? "active" : "")">@label</a>
                        </li>
                    }
                </ul>
                @* 右側：類型 + 搜尋 *@
                <form method="get" asp-action="Index" asp-controller="Promotions" class="d-flex gap-2 align-items-center">
                    <input type="hidden" name="status" value="@Model.StatusFilter" />
                    <select name="type" class="form-select form-select-sm" style="width:140px;" onchange="this.form.submit()">
                        <option value="" @@(Model.TypeFilter == null ? "selected=\"selected\"" : "")>所有類型</option>
                        <option value="1" @@(Model.TypeFilter == 1 ? "selected=\"selected\"" : "")>限時特賣</option>
                        <option value="2" @@(Model.TypeFilter == 2 ? "selected=\"selected\"" : "")>滿額折扣</option>
                        <option value="3" @@(Model.TypeFilter == 3 ? "selected=\"selected\"" : "")>限量搶購</option>
                    </select>
                    <div class="input-group input-group-sm" style="width:250px;">
                        <input type="text" name="keyword" value="@Model.Keyword" class="form-control" placeholder="搜尋活動名稱或賣家..." />
                        <button class="btn btn-primary" type="submit"><i class="bx bx-search"></i></button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Keyword) || Model.TypeFilter.HasValue)
                    {
                        <a href="@Url.Action("Index", new { status = Model.StatusFilter })" class="btn btn-sm btn-label-secondary">清除</a>
                    }
                </form>
            </div>
        </div>
    </div>

    @* 主表格 *@
    <div class="card shadow-sm" style="border-radius:0 0 12px 12px;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f8fafc; border-bottom:2px solid #e2e8f0;">
                    <tr>
                        <th style="color:#64748b;font-weight:600;font-size:.813rem;text-transform:uppercase;letter-spacing:.05em;">活動名稱</th>
                        <th style="color:#64748b;font-weight:600;font-size:.813rem;text-transform:uppercase;letter-spacing:.05em;">類型</th>
                        <th style="color:#64748b;font-weight:600;font-size:.813rem;text-transform:uppercase;letter-spacing:.05em;">時間區間</th>
                        <th style="color:#64748b;font-weight:600;font-size:.813rem;text-transform:uppercase;letter-spacing:.05em;">狀態</th>
                        <th style="color:#64748b;font-weight:600;font-size:.813rem;text-transform:uppercase;letter-spacing:.05em;">賣家</th>
                        <th class="text-end" style="color:#64748b;font-weight:600;font-size:.813rem;text-transform:uppercase;letter-spacing:.05em;">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        int _ni = 0;
                        @foreach (var item in Model.Items)
                        {
                            <tr class="@(item.IsPending ? "pending-row" : "")">
                                <td>
                                    <div class="promo-name">@item.Name</div>
                                    <div class="promo-desc">@item.ItemCount 個項目</div>
                                </td>
                                <td>
                                    <span class="badge @item.TypeBadgeClass">@item.TypeName</span>
                                </td>
                                <td style="font-size:.85rem; color:#64748b; white-space:nowrap;">
                                    <div><i class="bx bx-calendar me-1"></i>@item.StartTime.ToString("yyyy/MM/dd HH:mm")</div>
                                    <div class="text-muted">→ @item.EndTime.ToString("yyyy/MM/dd HH:mm")</div>
                                </td>
                                <td>
                                    <span class="badge @item.StatusBadgeClass">@item.DisplayStatus</span>
                                </td>
                                <td style="font-size:.875rem; color:#4a5568;">@item.SellerName</td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-end">
                                        <button type="button"
                                                class="act-icon"
                                                title="檢視"
                                                onclick="openPromotionOffcanvas(@item.Id, '@Html.Raw(item.Name.Replace("'", "\\'"))', @_ni)">
                                            <i class="bx bx-show"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            _ni++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div style="color:#a0aec0; font-size:2.5rem;"><i class="bx bx-purchase-tag"></i></div>
                                <h5 class="fw-normal mt-2" style="color:#718096;">找不到符合條件的活動</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* 分頁 *@
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white border-top">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="text-muted mb-0" style="font-size:.875rem;">
                            顯示第 @((Model.CurrentPage - 1) * Model.PageSize + 1)–@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)
                            筆，共 @Model.TotalCount 筆
                        </p>
                    </div>
                    <div class="col-md-6">
                        <nav>
                            <ul class="pagination justify-content-end mb-0">
                                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { keyword = Model.Keyword, status = Model.StatusFilter, type = Model.TypeFilter, page = Model.CurrentPage - 1 })">
                                        <i class="bx bx-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { keyword = Model.Keyword, status = Model.StatusFilter, type = Model.TypeFilter, page = i })">@i</a>
                                    </li>
                                }
                                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { keyword = Model.Keyword, status = Model.StatusFilter, type = Model.TypeFilter, page = Model.CurrentPage + 1 })">
                                        <i class="bx bx-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* ── Offcanvas：促銷活動詳情側邊欄 ── *@
<div class="offcanvas offcanvas-end" tabindex="-1" id="promotionDetailOffcanvas"
     style="width:50vw; min-width:440px; max-width:720px;">
    <div class="offcanvas-header border-bottom py-3">
        <h5 class="offcanvas-title fw-semibold" id="promotionDetailOffcanvasLabel" style="min-width:0; flex:1;">
            <i class="bx bx-purchase-tag-alt me-2" style="color:#3182ce;"></i>
            <span id="promotionOffcanvasTitle">促銷活動詳情</span>
        </h5>
        @* 快速導覽 ← → *@
        <div class="d-flex align-items-center gap-1 mx-2 flex-shrink-0">
            <span id="promoNavCounter" style="font-size:.78rem; color:#94a3b8; min-width:42px; text-align:center;"></span>
            <button type="button" class="btn btn-sm btn-outline-secondary px-2 py-1" id="promoNavPrev"
                    onclick="navigatePromotion(-1)" title="上一筆" disabled>
                <i class="bx bx-chevron-left" style="font-size:1rem;"></i>
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary px-2 py-1" id="promoNavNext"
                    onclick="navigatePromotion(1)" title="下一筆" disabled>
                <i class="bx bx-chevron-right" style="font-size:1rem;"></i>
            </button>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="關閉"></button>
    </div>
    <div class="offcanvas-body p-0 overflow-auto" id="promotionDetailOffcanvasBody">
        <div class="d-flex align-items-center justify-content-center" style="height:200px;">
            <div class="text-center text-muted">
                <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                <div>載入中…</div>
            </div>
        </div>
    </div>
</div>

@* 拒絕原因 Modal *@
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
        <div class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold" style="color:#1e2d3d;">
                    <i class="bx bx-x-circle me-2 text-danger"></i>拒絕活動
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3" style="font-size:.875rem;">
                    活動：<strong id="rejectModalName"></strong>
                </p>
                <div class="mb-2">
                    <div style="font-size:.8rem; color:#64748b; margin-bottom:.4rem;">常用原因快選：</div>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var qr in new[]{"圖片不符規範","折扣幅度異常","活動描述不清","時間區間有誤","商品資訊不完整"})
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    style="font-size:.78rem; padding:3px 10px;"
                                    onclick="setRejectReason('@qr')">@qr</button>
                        }
                    </div>
                </div>
                <label class="form-label fw-semibold">拒絕原因 <span class="text-danger">*</span></label>
                <textarea id="rejectReasonInput" class="form-control" rows="4"
                          placeholder="請說明拒絕原因，此訊息將通知賣家..."></textarea>
                <div id="rejectReasonError" class="text-danger mt-1" style="font-size:.813rem; display:none;">請填寫拒絕原因</div>
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-danger" id="rejectConfirmBtn" onclick="submitReject()">
                    <i class="bx bx-send me-1"></i>送出拒絕
                </button>
            </div>
        </div>
    </div>
</div>

@* AJAX 用 antiforgery form *@
<form id="actionForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
<script>
    // ── 促銷列表（供導覽用）──
    var _promoList = [
        @{ bool _pf = true; }
        @foreach (var it in Model.Items) {
            if (!_pf){<text>,</text>} _pf = false;
            <text>{ id: @it.Id, name: '@Html.Raw(it.Name.Replace("\\","\\\\").Replace("'","\\'").Replace("\n","").Replace("\r",""))' }</text>
        }
    ];
    var _currentNavIdx = -1;

    // ── 開啟 Offcanvas 並 AJAX 載入詳情 ──
    var _promoDetailUrl = '@Url.Action("GetPromotionDetailsPartial", "Promotions")';

    function openPromotionOffcanvas(id, name, idx) {
        _currentNavIdx = (idx !== undefined) ? idx : -1;
        _updateNavButtons();
        var body    = document.getElementById('promotionDetailOffcanvasBody');
        var titleEl = document.getElementById('promotionOffcanvasTitle');
        if (titleEl) titleEl.textContent = name || '促銷活動詳情';
        body.innerHTML =
            '<div class="d-flex align-items-center justify-content-center" style="height:200px;">' +
            '<div class="text-center text-muted">' +
            '<div class="spinner-border spinner-border-sm mb-2" role="status"></div>' +
            '<div>載入中…</div></div></div>';
        bootstrap.Offcanvas.getOrCreateInstance(
            document.getElementById('promotionDetailOffcanvas')).show();
        fetch(_promoDetailUrl + '?id=' + id)
            .then(function (res) { if (!res.ok) throw new Error('HTTP ' + res.status); return res.text(); })
            .then(function (html) { body.innerHTML = html; })
            .catch(function () {
                body.innerHTML =
                    '<div class="text-center py-5 text-danger">' +
                    '<i class="bx bx-error-circle" style="font-size:2.5rem;"></i>' +
                    '<div class="mt-2">載入失敗，請稍後再試</div></div>';
            });
    }

    // ── 導覽上/下一筆 ──
    function navigatePromotion(delta) {
        var next = _currentNavIdx + delta;
        if (next < 0 || next >= _promoList.length) return;
        var p = _promoList[next];
        openPromotionOffcanvas(p.id, p.name, next);
    }

    function _updateNavButtons() {
        var prev    = document.getElementById('promoNavPrev');
        var next    = document.getElementById('promoNavNext');
        var counter = document.getElementById('promoNavCounter');
        var total   = _promoList.length;
        if (prev)    prev.disabled    = _currentNavIdx <= 0;
        if (next)    next.disabled    = _currentNavIdx < 0 || _currentNavIdx >= total - 1;
        if (counter) counter.textContent = total > 0 && _currentNavIdx >= 0
            ? (_currentNavIdx + 1) + ' / ' + total : '';
    }

    // ── 核准 ──
    async function approvePromotion(id, name) {
        const doApprove = async () => {
            const token = document.querySelector('#actionForm [name="__RequestVerificationToken"]').value;
            const fd = new FormData();
            fd.append('__RequestVerificationToken', token);
            const res = await fetch(`/Promotions/Approve/${id}`, {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd
            });
            const result = await res.json();
            if (result.success) {
                showMsg('success', result.message);
                setTimeout(() => location.reload(), 1500);
            } else {
                showMsg('error', result.message);
            }
        };

        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'question', title: '確認核准',
                text: `確定要核准活動「${name}」嗎？`,
                showCancelButton: true,
                confirmButtonColor: '#10b981',
                confirmButtonText: '核准', cancelButtonText: '取消'
            }).then(r => { if (r.isConfirmed) doApprove(); });
        } else {
            if (confirm(`確定要核准活動「${name}」嗎？`)) doApprove();
        }
    }

    // ── 拒絕 Modal ──
    var _rejectTargetId = null;

    function openRejectModal(id, name) {
        _rejectTargetId = id;
        document.getElementById('rejectModalName').textContent = name;
        document.getElementById('rejectReasonInput').value = '';
        document.getElementById('rejectReasonError').style.display = 'none';
        new bootstrap.Modal(document.getElementById('rejectModal')).show();
    }

    async function submitReject() {
        const reason = document.getElementById('rejectReasonInput').value.trim();
        if (!reason) {
            document.getElementById('rejectReasonError').style.display = 'block';
            return;
        }
        document.getElementById('rejectReasonError').style.display = 'none';

        const btn = document.getElementById('rejectConfirmBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>送出中...';

        const token = document.querySelector('#actionForm [name="__RequestVerificationToken"]').value;
        const fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        fd.append('reason', reason);

        const res = await fetch(`/Promotions/Reject/${_rejectTargetId}`, {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd
        });
        const result = await res.json();

        bootstrap.Modal.getInstance(document.getElementById('rejectModal')).hide();
        btn.disabled = false;
        btn.innerHTML = '<i class="bx bx-send me-1"></i>送出拒絕';

        if (result.success) {
            showMsg('success', result.message);
            setTimeout(() => location.reload(), 1500);
        } else {
            showMsg('error', result.message);
        }
    }

    function showMsg(type, msg) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({ icon: type, text: msg, timer: type === 'success' ? 1800 : undefined, showConfirmButton: type !== 'success' });
        } else { alert(msg); }
    }

    // ── 拒絕 Modal 快速原因填入 ──
    function setRejectReason(text) {
        document.getElementById('rejectReasonInput').value = text;
        document.getElementById('rejectReasonError').style.display = 'none';
        document.getElementById('rejectReasonInput').focus();
    }
</script>
}
