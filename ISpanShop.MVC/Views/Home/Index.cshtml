<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<div class="container mt-4" style="border: 2px dashed #007bff; padding: 20px; border-radius: 10px;">
    <h3 class="text-primary">⚡ SignalR 即時通訊測試區</h3>

    <div class="row">
        <div class="col-md-3">
            <label class="small text-muted">我的 ID (Sender)</label>
            <input type="number" id="myId" class="form-control mb-2" value="9" />
        </div>
        <div class="col-md-3">
            <label class="small text-muted">對象 ID (Receiver)</label>
            <input type="number" id="receiverId" class="form-control mb-2" value="14" />
        </div>
        <div class="col-md-4">
            <label class="small text-muted">測試訊息</label>
            <input type="text" id="messageInput" placeholder="輸入訊息..." class="form-control mb-2" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button id="sendButton" class="btn btn-primary w-100 mb-2">發送</button>
        </div>
    </div>
    <hr />
    <ul id="messagesList" class="list-group">
    </ul>
</div>

<script>
    // 1. 建立連線 (確保 Port 7028 是正確的 HTTPS Port)
    const connection = new signalR.HubConnectionBuilder()
    .withUrl("https://localhost:7028/chatHub")
    .withAutomaticReconnect()
    .build();

    // 2. 接收後端推播
    connection.on("ReceiveMessage", function (senderId, content, type, time) {
        const li = document.createElement("li");
        li.className = "list-group-item list-group-item-info";
        li.textContent = `[${time}] 用戶 ${senderId} 說: ${content}`;
        document.getElementById("messagesList").prepend(li);
    });

    connection.on("ErrorMessage", function (errorMsg) {
        alert("系統提示：" + errorMsg);
    });

    // 3. 啟動連線
    connection.start().then(function () {
        console.log("🟢 SignalR 連線成功！");
        const li = document.createElement("li");
        li.className = "list-group-item list-group-item-success";
        li.textContent = "已成功連線到通訊伺服器！";
        document.getElementById("messagesList").appendChild(li);
    }).catch(function (err) {
        return console.error("🔴 連線失敗: ", err.toString());
    });

    // 4. 綁定發送按鈕
    document.getElementById("sendButton").addEventListener("click", function (event) {
        // 抓取畫面上三個數值
        const myId = parseInt(document.getElementById("myId").value);
        const receiverId = parseInt(document.getElementById("receiverId").value);
        const message = document.getElementById("messageInput").value;
        const type = 1; // 1 代表文字

        // ⚠️ 呼叫後端方法，傳入 4 個參數
        connection.invoke("SendPrivateMessage", myId, receiverId, message, type)
            .catch(function (err) {
                return console.error("發送失敗: ", err.toString());
            });

        document.getElementById("messageInput").value = '';
        event.preventDefault();
    });
</script>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>