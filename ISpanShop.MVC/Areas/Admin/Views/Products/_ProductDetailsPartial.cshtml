@model ISpanShop.MVC.Areas.Admin.Models.Products.ProductDetailVm
@using System.Text.Json

@{
    // ── 狀態 badge 樣式 ──
    var (stBg, stColor, stIcon) = Model?.Status switch
    {
        1 => ("#e6f4ea", "#1b5e20", "bx-check-circle"),
        2 => ("#fff8e1", "#e65100", "bx-time-five"),
        3 => ("#fde8e8", "#b71c1c", "bx-x-circle"),
        0 => ("#f5f5f5", "#424242", "bx-minus-circle"),
        _ => ("#f5f5f5", "#424242", "bx-minus-circle")
    };
    var stBorder = Model?.Status switch
    {
        1 => "#c8e6c9",
        2 => "#ffe082",
        3 => "#ffcdd2",
        _ => "#e0e0e0"
    };

    // ── 規格維度解析 ──
    var dimNames = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model?.SpecDefinitionJson) && Model.SpecDefinitionJson != "[]")
    {
        try
        {
            var arr = JsonSerializer.Deserialize<JsonElement[]>(Model.SpecDefinitionJson);
            if (arr != null)
                dimNames = arr
                    .Where(el => el.TryGetProperty("name", out _))
                    .Select(el => el.GetProperty("name").GetString() ?? "")
                    .Where(n => n.Length > 0)
                    .ToList();
        }
        catch { }
    }
    if (dimNames.Count == 0 && Model?.Variants != null)
    {
        var firstWithSpec = Model.Variants.FirstOrDefault(v => !v.IsDeleted && v.SpecValues.Count > 0);
        if (firstWithSpec != null) dimNames = firstWithSpec.SpecValues.Keys.ToList();
    }
    bool hasMultiDims = dimNames.Count > 0;

    int variantCount = Model?.Variants?.Count(v => !v.IsDeleted) ?? 0;
    int imageCount   = Model?.Images?.Count ?? 0;
    int totalStock   = Model?.Variants?.Where(v => !v.IsDeleted).Sum(v => v.Stock ?? 0) ?? 0;
}

@* ════════════════════════════════════════════════
   圖片輪播
   ════════════════════════════════════════════════ *@
@if (Model.Images != null && Model.Images.Any())
{
    <div id="ocCarousel" class="carousel slide carousel-dark mb-0" data-bs-ride="false">
        <div class="carousel-inner" style="background:#f3f4f6;border-radius:0;">
            @for (int i = 0; i < Model.Images.Count; i++)
            {
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    <img src="@Model.Images[i]"
                         alt="商品圖片 @(i + 1)"
                         loading="lazy"
                         style="width:100%;max-height:340px;object-fit:contain;display:block;background:#f3f4f6;" />
                </div>
            }
        </div>
        @if (Model.Images.Count > 1)
        {
            <button class="carousel-control-prev" type="button"
                    data-bs-target="#ocCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
                <span class="visually-hidden">上一張</span>
            </button>
            <button class="carousel-control-next" type="button"
                    data-bs-target="#ocCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
                <span class="visually-hidden">下一張</span>
            </button>

            @* 縮圖列 *@
            <div class="d-flex gap-2 px-3 py-2 overflow-auto" style="background:#fff;border-top:1px solid #f0f0f0;">
                @for (int i = 0; i < Model.Images.Count; i++)
                {
                    <img src="@Model.Images[i]"
                         class="oc-thumb"
                         alt="縮圖 @(i + 1)"
                         loading="lazy"
                         data-bs-target="#ocCarousel"
                         data-bs-slide-to="@i" />
                }
            </div>
        }
    </div>
}
else
{
    <div class="d-flex flex-column align-items-center justify-content-center gap-2 mb-0"
         style="height:220px;background:#f3f4f6;color:#9ca3af;">
        <i class="bx bx-image-alt" style="font-size:3.5rem;"></i>
        <span style="font-size:.95rem;">尚無商品圖片</span>
    </div>
}

@* ════════════════════════════════════════════════
   主內容區（帶 padding）
   ════════════════════════════════════════════════ *@
<div class="p-4">

    @* ── 退回原因橫幅（置頂提示） ── *@
    @if (Model.Status == 3 && !string.IsNullOrWhiteSpace(Model.RejectReason))
    {
        <div class="d-flex gap-3 p-3 mb-4 rounded-3"
             style="background:#fff5f5;border:1px solid #ffcdd2;">
            <i class="bx bx-error-circle text-danger mt-1" style="font-size:1.4rem;flex-shrink:0;"></i>
            <div>
                <div class="fw-bold text-danger mb-1" style="font-size:.95rem;">審核退回原因</div>
                <div style="font-size:.95rem;color:#374151;line-height:1.7;">@Model.RejectReason</div>
            </div>
        </div>
    }

    @* ── 分類標籤列 ── *@
    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="badge rounded-pill bg-label-primary" style="font-size:.82rem;padding:5px 12px;">
            <i class="bx bx-store me-1"></i>@Model.StoreName
        </span>
        @if (!string.IsNullOrEmpty(Model.CategoryName))
        {
            <span class="badge rounded-pill bg-label-success" style="font-size:.82rem;padding:5px 12px;">
                <i class="bx bx-category me-1"></i>@Model.CategoryName
            </span>
        }
        @if (!string.IsNullOrEmpty(Model.BrandName))
        {
            <span class="badge rounded-pill bg-label-warning" style="font-size:.82rem;padding:5px 12px;">
                <i class="bx bx-purchase-tag me-1"></i>@Model.BrandName
            </span>
        }
    </div>

    @* ── 商品名稱 ── *@
    <h4 class="fw-bold mb-2" style="color:#1e2d3d;line-height:1.4;">@Model.Name</h4>

    @* ── 狀態 + 申請日期 ── *@
    <div class="d-flex align-items-center gap-3 mb-4">
        <span style="display:inline-flex;align-items:center;gap:6px;
                     background:@stBg;color:@stColor;border:1px solid @stBorder;
                     padding:5px 14px;border-radius:20px;font-size:.9rem;font-weight:600;">
            <i class="bx @stIcon"></i>@Model.StatusText
        </span>
        @if (Model.CreatedAt.HasValue)
        {
            <span style="font-size:.88rem;color:#9ca3af;">
                <i class="bx bx-calendar me-1"></i>@Model.CreatedAt.Value.ToString("yyyy-MM-dd")
            </span>
        }
    </div>

    @* ── 價格 ── *@
    @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
    {
        <div class="mb-4 p-3 rounded-3" style="background:#f0fdf4;border:1px solid #bbf7d0;">
            <div style="font-size:.78rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">售價範圍</div>
            <div class="fw-bold" style="font-size:1.6rem;color:#15803d;">
                @if (Model.MinPrice == Model.MaxPrice)
                {
                    @($"NT$ {Model.MinPrice:N0}")
                }
                else
                {
                    @($"NT$ {Model.MinPrice:N0}")
                    <span style="font-size:1.1rem;color:#6b7280;font-weight:400;margin:0 6px;">~</span>
                    @($"NT$ {Model.MaxPrice:N0}")
                }
            </div>
        </div>
    }

    @* ── 四格數據儀表板 ── *@
    <div class="row g-3 mb-4">
        <div class="col-6">
            <div class="oc-stat-card">
                <div class="oc-stat-icon" style="background:#ede9fe;color:#7c3aed;">
                    <i class="bx bx-cube"></i>
                </div>
                <div class="oc-stat-body">
                    <div class="oc-stat-label">規格數</div>
                    <div class="oc-stat-value">@variantCount</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="oc-stat-card">
                <div class="oc-stat-icon" style="background:#dbeafe;color:#1d4ed8;">
                    <i class="bx bx-image"></i>
                </div>
                <div class="oc-stat-body">
                    <div class="oc-stat-label">圖片數</div>
                    <div class="oc-stat-value">@imageCount</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="oc-stat-card">
                <div class="oc-stat-icon" style="background:#fef9c3;color:#a16207;">
                    <i class="bx bx-trending-up"></i>
                </div>
                <div class="oc-stat-body">
                    <div class="oc-stat-label">總銷量</div>
                    <div class="oc-stat-value">@(Model.TotalSales?.ToString("N0") ?? "—")</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="oc-stat-card">
                <div class="oc-stat-icon" style="background:#dcfce7;color:#15803d;">
                    <i class="bx bx-package"></i>
                </div>
                <div class="oc-stat-body">
                    <div class="oc-stat-label">總庫存</div>
                    <div class="oc-stat-value">@totalStock.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    @* ── 商品描述 ── *@
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <div class="mb-4">
            <div class="oc-section-label mb-2">
                <i class="bx bx-notepad me-1"></i>商品描述
            </div>
            <div class="p-3 rounded-3" style="background:#f8f9fa;border-left:3px solid #d1d5db;font-size:1rem;line-height:1.85;color:#374151;">
                @Model.Description
            </div>
        </div>
    }

    @* ── 審核歷程時間軸 ── *@
    <div class="mb-4">
        <div class="oc-section-label mb-3">
            <i class="bx bx-history me-1"></i>審核歷程
        </div>
        <div class="audit-timeline">
            @if (Model.UpdatedAt.HasValue)
            {
                <div class="tl-item">
                    <div class="tl-dot tl-dot-gray"></div>
                    <div class="tl-body">
                        <div class="tl-label">最後更新</div>
                        <div class="tl-time">@Model.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")</div>
                    </div>
                </div>
            }
            @if (Model.ReviewStatus == 1)
            {
                <div class="tl-item">
                    <div class="tl-dot tl-dot-green"></div>
                    <div class="tl-body">
                        <div class="tl-label">
                            審核通過
                            @if (!string.IsNullOrEmpty(Model.ReviewedBy))
                            {
                                <span class="tl-reviewer">by @Model.ReviewedBy</span>
                            }
                        </div>
                        <div class="tl-time">@(Model.ReviewDate?.ToString("yyyy/MM/dd HH:mm") ?? "—")</div>
                    </div>
                </div>
            }
            else if (Model.ReviewStatus == 2)
            {
                <div class="tl-item">
                    <div class="tl-dot tl-dot-red"></div>
                    <div class="tl-body">
                        <div class="tl-label">
                            審核退回
                            @if (!string.IsNullOrEmpty(Model.ReviewedBy))
                            {
                                <span class="tl-reviewer">by @Model.ReviewedBy</span>
                            }
                        </div>
                        <div class="tl-time">@(Model.ReviewDate?.ToString("yyyy/MM/dd HH:mm") ?? "—")</div>
                    </div>
                </div>
            }
            else
            {
                <div class="tl-item">
                    <div class="tl-dot tl-dot-yellow"></div>
                    <div class="tl-body">
                        <div class="tl-label">等待審核中</div>
                    </div>
                </div>
            }
            @if (Model.CreatedAt.HasValue)
            {
                <div class="tl-item tl-last">
                    <div class="tl-dot tl-dot-gray"></div>
                    <div class="tl-body">
                        <div class="tl-label">建檔</div>
                        <div class="tl-time">@Model.CreatedAt.Value.ToString("yyyy/MM/dd HH:mm")</div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* ── 規格與庫存明細 ── *@
    @if (Model.Variants != null && Model.Variants.Any(v => !v.IsDeleted))
    {
        <div class="oc-section-label mb-3">
            <i class="bx bx-list-ul me-1"></i>規格與庫存明細
        </div>
        <div class="table-responsive rounded-3 overflow-hidden" style="border:1px solid #e5e7eb;">
            <table class="table table-hover align-middle mb-0" style="font-size:.95rem;">
                <thead>
                    <tr style="background:#f8f9fa;">
                        <th class="oc-th">SKU</th>
                        @if (hasMultiDims)
                        {
                            foreach (var dim in dimNames) { <th class="oc-th">@dim</th> }
                        }
                        else
                        {
                            <th class="oc-th">規格</th>
                        }
                        <th class="oc-th text-end">售價</th>
                        <th class="oc-th text-center">庫存</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Variants.Where(v => !v.IsDeleted))
                    {
                        var stock = v.Stock ?? 0;
                        <tr>
                            <td class="oc-td">
                                <code class="oc-sku">@v.SkuCode</code>
                            </td>
                            @if (hasMultiDims)
                            {
                                foreach (var dim in dimNames)
                                {
                                    var cellVal = v.SpecValues.TryGetValue(dim, out var sv) ? sv : "—";
                                    <td class="oc-td fw-medium">@cellVal</td>
                                }
                            }
                            else
                            {
                                <td class="oc-td fw-medium">@v.VariantName</td>
                            }
                            <td class="oc-td text-end fw-bold" style="color:#1d4ed8;">NT$ @v.Price.ToString("N0")</td>
                            <td class="oc-td text-center">
                                @if (stock > 10)
                                {
                                    <span class="oc-stock" style="background:#dcfce7;color:#15803d;">@stock 件</span>
                                }
                                else if (stock > 0)
                                {
                                    <span class="oc-stock" style="background:#fef9c3;color:#a16207;">緊張 @stock 件</span>
                                }
                                else
                                {
                                    <span class="oc-stock" style="background:#fee2e2;color:#b91c1c;">售罄</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>@* /p-4 *@

<style>
    /* ── 縮圖 ── */
    .oc-thumb {
        width: 60px; height: 60px; object-fit: cover; border-radius: 8px;
        cursor: pointer; opacity: .65; border: 2px solid transparent;
        transition: all .2s ease; flex-shrink: 0;
    }
    .oc-thumb:hover { opacity: 1; border-color: #0d9488; transform: translateY(-2px); }

    /* ── 區塊標題 ── */
    .oc-section-label {
        font-size: .78rem; font-weight: 700; color: #9ca3af;
        text-transform: uppercase; letter-spacing: 1.2px;
    }

    /* ── 數據卡片 ── */
    .oc-stat-card {
        display: flex; align-items: center; gap: 14px;
        background: #fff; border: 1px solid #e5e7eb;
        border-radius: 12px; padding: 14px 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }
    .oc-stat-icon {
        width: 44px; height: 44px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.35rem; flex-shrink: 0;
    }
    .oc-stat-label { font-size: .78rem; color: #9ca3af; font-weight: 600; margin-bottom: 2px; }
    .oc-stat-value { font-size: 1.3rem; font-weight: 700; color: #1e2d3d; line-height: 1; }

    /* ── 時間軸 ── */
    .audit-timeline { position: relative; }
    .tl-item { display: flex; align-items: flex-start; gap: 14px; position: relative; padding-bottom: 16px; }
    .tl-item::before {
        content: ''; position: absolute; left: 7px; top: 18px;
        width: 2px; bottom: 0; background: #e5e7eb;
    }
    .tl-last::before { display: none; }
    .tl-dot {
        width: 16px; height: 16px; border-radius: 50%; flex-shrink: 0;
        margin-top: 3px; position: relative; z-index: 1; border: 2px solid;
    }
    .tl-dot-gray   { background: #f3f4f6; border-color: #9ca3af; }
    .tl-dot-green  { background: #dcfce7; border-color: #22c55e; }
    .tl-dot-red    { background: #fee2e2; border-color: #ef4444; }
    .tl-dot-yellow { background: #fef9c3; border-color: #eab308; }
    .tl-body { min-width: 0; }
    .tl-label    { font-size: .95rem; font-weight: 600; color: #374151; line-height: 1.5; }
    .tl-reviewer { font-weight: 400; color: #9ca3af; font-size: .88rem; }
    .tl-time     { font-size: .85rem; color: #9ca3af; margin-top: 2px; }

    /* ── 規格表 ── */
    .oc-th {
        font-size: .8rem; font-weight: 700; color: #9ca3af;
        text-transform: uppercase; letter-spacing: .5px;
        padding: .8rem 1rem; border-bottom: 1px solid #e5e7eb !important;
        white-space: nowrap;
    }
    .oc-td { padding: .8rem 1rem; border-bottom: 1px solid #f3f4f6; font-size: .95rem; }

    /* ── SKU code ── */
    .oc-sku {
        background: #f3f4f6; color: #566a7f;
        padding: 3px 8px; border-radius: 5px; font-size: .82rem;
    }

    /* ── 庫存 badge ── */
    .oc-stock { padding: 3px 10px; border-radius: 8px; font-size: .85rem; font-weight: 600; }
</style>
