@model ISpanShop.MVC.Areas.Admin.Models.Promotions.PromotionDetailVm

<style>
    .pd-info-row { display: flex; padding: .55rem 0; border-bottom: 1px solid #f1f5f9; }
    .pd-info-row:last-child { border-bottom: none; }
    .pd-info-label { width: 110px; font-size: .82rem; color: #94a3b8; flex-shrink: 0; padding-right: .5rem; line-height: 1.6; padding-top: .1rem; }
    .pd-info-value { font-size: .9rem; color: #1e2d3d; font-weight: 500; line-height: 1.6; }
    .pd-progress-time { height: 8px; border-radius: 4px; }
    .pd-items-table th, .pd-items-table td { font-size: .85rem !important; vertical-align: middle; }
    .pd-review-panel { border-radius: 12px; border: 2px solid #f59e0b; background: #fffbeb; padding: 1.25rem; }
    .pd-reject-banner { background: #fff5f5; border-left: 4px solid #ea5455; border-radius: 6px; padding: .75rem 1rem; }
</style>

@{
    var now = DateTime.Now;
    var isActive = Model.Status == 1 && now >= Model.StartTime && now <= Model.EndTime;
}

<div class="p-3 p-md-4 font-noto" style="font-family:'Public Sans',sans-serif;">

    @* ── 狀態徽章列 ── *@
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <span class="badge @Model.TypeBadgeClass" style="font-size:.8rem; padding:5px 10px;">@Model.TypeName</span>
        <span class="badge @Model.StatusBadgeClass" style="font-size:.8rem; padding:5px 10px;">@Model.DisplayStatus</span>
        <span class="text-muted ms-auto" style="font-size:.8rem;">ID #@Model.Id</span>
    </div>

    @* ── 活動標題 ── *@
    <h5 class="fw-bold mb-1" style="color:#1e2d3d; word-break:break-word;">@Model.Name</h5>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="text-muted mb-3" style="font-size:.875rem; line-height:1.7;">@Model.Description</p>
    }

    @* ── 拒絕理由 Banner（若已拒絕） ── *@
    @if (Model.Status == 2 && !string.IsNullOrWhiteSpace(Model.RejectReason))
    {
        <div class="pd-reject-banner mb-3">
            <div class="fw-semibold text-danger mb-1" style="font-size:.85rem;">
                <i class="bx bx-error-circle me-1"></i>拒絕理由
            </div>
            <div style="font-size:.875rem; color:#c0392b;">@Model.RejectReason</div>
        </div>
    }

    @* ── 基本資訊 ── *@
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-white border-bottom py-2">
            <h6 class="mb-0 fw-bold" style="color:#1e2d3d; font-size:.9rem;">
                <i class="bx bx-info-circle me-2" style="color:#3182ce;"></i>活動資訊
            </h6>
        </div>
        <div class="card-body py-2">
            <div class="pd-info-row">
                <span class="pd-info-label">賣家</span>
                <span class="pd-info-value">@Model.SellerName</span>
            </div>
            <div class="pd-info-row">
                <span class="pd-info-label">開始時間</span>
                <span class="pd-info-value">@Model.StartTime.ToString("yyyy/MM/dd HH:mm")</span>
            </div>
            <div class="pd-info-row">
                <span class="pd-info-label">結束時間</span>
                <span class="pd-info-value">@Model.EndTime.ToString("yyyy/MM/dd HH:mm")</span>
            </div>
            <div class="pd-info-row">
                <span class="pd-info-label">建立時間</span>
                <span class="pd-info-value">@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
            </div>
            @if (Model.ReviewedAt.HasValue)
            {
                <div class="pd-info-row">
                    <span class="pd-info-label">審核時間</span>
                    <span class="pd-info-value">@Model.ReviewedAt.Value.ToString("yyyy/MM/dd HH:mm")</span>
                </div>
            }
        </div>
    </div>

    @* ── 時間進度條（進行中才顯示） ── *@
    @if (Model.Status == 1)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-body py-3">
                <div class="d-flex justify-content-between mb-2" style="font-size:.82rem; color:#64748b;">
                    <span><i class="bx bx-calendar me-1"></i>@Model.StartTime.ToString("MM/dd")</span>
                    <span class="fw-semibold" style="color:#3182ce;">@Model.ProgressPercent%</span>
                    <span>@Model.EndTime.ToString("MM/dd")<i class="bx bx-calendar-check ms-1"></i></span>
                </div>
                <div class="progress pd-progress-time">
                    <div class="progress-bar @(isActive ? "bg-success" : "bg-primary")"
                         style="width:@Model.ProgressPercent%"></div>
                </div>
                <div class="text-center mt-2" style="font-size:.8rem; color:#94a3b8;">
                    @if (!isActive && now < Model.StartTime)
                    {
                        <span>距開始 @((int)(Model.StartTime - now).TotalDays) 天</span>
                    }
                    else if (isActive)
                    {
                        <span>距結束 @((int)(Model.EndTime - now).TotalDays) 天</span>
                    }
                </div>
            </div>
        </div>
    }

    @* ── 折扣規則 / 活動商品 ── *@
    @if (Model.PromotionType == 2)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-2">
                <h6 class="mb-0 fw-bold" style="color:#1e2d3d; font-size:.9rem;">
                    <i class="bx bx-receipt me-2" style="color:#0ea5e9;"></i>折扣規則
                    <span class="badge bg-label-secondary ms-2">@Model.Rules.Count 條</span>
                </h6>
            </div>
            <div class="card-body p-0">
                @if (Model.Rules.Any())
                {
                    <table class="table pd-items-table mb-0">
                        <thead style="background:#f8fafc;">
                            <tr>
                                <th>規則類型</th>
                                <th>門檻</th>
                                <th>折扣方式</th>
                                <th>折扣值</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rule in Model.Rules)
                            {
                                <tr>
                                    <td><span class="badge bg-label-info">@rule.RuleTypeName</span></td>
                                    <td class="fw-semibold">@rule.Threshold.ToString("N0") @(rule.RuleType == 1 ? "元" : "件")</td>
                                    <td>@rule.DiscountTypeName</td>
                                    <td class="fw-semibold" style="color:#10b981;">
                                        @(rule.DiscountType == 1 ? $"折抵 {rule.DiscountValue:N0} 元" : $"打 {rule.DiscountValue}% 折")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-3 text-muted" style="font-size:.875rem;">尚無規則</div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-2">
                <h6 class="mb-0 fw-bold" style="color:#1e2d3d; font-size:.9rem;">
                    <i class="bx bx-package me-2" style="color:#f59e0b;"></i>
                    @(Model.PromotionType == 3 ? "搶購商品" : "活動商品")
                    <span class="badge bg-label-secondary ms-2">@Model.Items.Count 件</span>
                </h6>
            </div>
            <div class="card-body p-0">
                @if (Model.Items.Any())
                {
                    <table class="table pd-items-table mb-0">
                        <thead style="background:#f8fafc;">
                            <tr>
                                <th>商品名稱</th>
                                <th>原價</th>
                                <th>活動價</th>
                                <th>折扣</th>
                                @if (Model.PromotionType == 3)
                                {
                                    <th>限購</th>
                                    <th>庫存/售</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                var discount = item.DiscountPrice.HasValue
                                    ? (decimal)(item.OriginalPrice - item.DiscountPrice.Value) / item.OriginalPrice * 100
                                    : 0;
                                <tr>
                                    <td class="fw-semibold" style="word-break:break-word; max-width:160px;">@item.ProductName</td>
                                    <td style="color:#94a3b8; text-decoration:line-through;">NT$ @item.OriginalPrice.ToString("N0")</td>
                                    <td class="fw-bold" style="color:#ea5455;">
                                        @(item.DiscountPrice.HasValue ? $"NT$ {item.DiscountPrice.Value:N0}" : "-")
                                    </td>
                                    <td>
                                        @if (discount > 0)
                                        {
                                            <span class="badge bg-label-danger">-@discount.ToString("N0")%</span>
                                        }
                                    </td>
                                    @if (Model.PromotionType == 3)
                                    {
                                        <td>@(item.QuantityLimit.HasValue ? $"{item.QuantityLimit} 件" : "不限")</td>
                                        <td>@(item.StockLimit.HasValue ? item.StockLimit.ToString() : "∞") / @item.SoldCount</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-3 text-muted" style="font-size:.875rem;">尚無商品</div>
                }
            </div>
        </div>
    }

    @* ── 審核區塊（待審核時顯示） ── *@
    @if (Model.IsPending)
    {
        <div class="pd-review-panel mb-3">
            <h6 class="fw-bold mb-3" style="color:#92400e; font-size:.9rem;">
                <i class="bx bx-check-shield me-2"></i>審核此活動
            </h6>
            <div class="d-flex gap-2 mb-3">
                <button type="button" class="btn btn-success flex-fill" onclick="pdApprovePromotion(@Model.Id)">
                    <i class="bx bx-check me-1"></i>核准
                </button>
                <button type="button" class="btn btn-danger flex-fill" onclick="pdToggleRejectPanel()">
                    <i class="bx bx-x me-1"></i>拒絕
                </button>
            </div>
            <div id="pdRejectPanel" style="display:none;">
                <label class="form-label fw-semibold text-danger" style="font-size:.875rem;">
                    <i class="bx bx-error-circle me-1"></i>拒絕理由 <span class="text-danger">*</span>
                </label>
                <textarea id="pdRejectReason" class="form-control mb-2" rows="3"
                          placeholder="請說明拒絕原因，此訊息將通知賣家..."></textarea>
                <button type="button" class="btn btn-danger w-100" onclick="pdRejectPromotion(@Model.Id)">
                    <i class="bx bx-send me-1"></i>送出拒絕
                </button>
            </div>
        </div>
    }


</div>

@* ── Offcanvas 底部操作欄（sticky，不隨內容捲動） ── *@
<div class="border-top bg-white px-3 py-2 d-flex justify-content-end gap-2"
     style="position:sticky; bottom:0; z-index:5;">
    <button type="button" class="btn btn-outline-secondary"
            data-bs-dismiss="offcanvas">
        <i class="bx bx-x me-1"></i>關閉
    </button>
    @if (Model.CanEdit || Model.IsActiveOnly)
    {
        <a href="/Admin/Promotions/Edit/@Model.Id" class="btn btn-primary">
            <i class="bx bx-edit me-1"></i>進入完整編輯頁
        </a>
    }
</div>

@* antiforgery 供 AJAX POST 使用 *@
<form id="pdActionForm" method="post" style="display:none;">@Html.AntiForgeryToken()</form>

<script>
    function pdToggleRejectPanel() {
        var panel = document.getElementById('pdRejectPanel');
        panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    }

    async function pdApprovePromotion(id) {
        var name = @Html.Raw($"'{Model.Name.Replace("'", "\\'")}'");
        var ok = await _pdConfirm('確認核准', '確定要核准活動「' + name + '」嗎？');
        if (!ok) return;
        var token = document.querySelector('#pdActionForm [name="__RequestVerificationToken"]').value;
        var fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        var res = await fetch('/Admin/Promotions/Approve/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd });
        var result = await res.json();
        _pdMsg(result.success ? 'success' : 'error', result.message);
        if (result.success) setTimeout(function () { location.reload(); }, 1500);
    }

    async function pdRejectPromotion(id) {
        var reason = document.getElementById('pdRejectReason').value.trim();
        if (!reason) { _pdMsg('error', '請填寫拒絕理由'); return; }
        var token = document.querySelector('#pdActionForm [name="__RequestVerificationToken"]').value;
        var fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        fd.append('reason', reason);
        var res = await fetch('/Admin/Promotions/Reject/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd });
        var result = await res.json();
        _pdMsg(result.success ? 'success' : 'error', result.message);
        if (result.success) setTimeout(function () { location.reload(); }, 1500);
    }

    function _pdConfirm(title, text) {
        if (typeof Swal !== 'undefined') {
            return Swal.fire({ icon: 'question', title: title, text: text, showCancelButton: true, confirmButtonText: '確認', cancelButtonText: '取消' }).then(function (r) { return r.isConfirmed; });
        }
        return Promise.resolve(confirm(text));
    }

    function _pdMsg(type, msg) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({ icon: type, text: msg, timer: type === 'success' ? 1800 : undefined, showConfirmButton: type !== 'success' });
        } else { alert(msg); }
    }
</script>
