@model IEnumerable<ISpanShop.Models.EfModels.Order>

@{
    ViewData["Title"] = "金流與付款紀錄";
    Layout = "_SneatLayout";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <!-- 頁面標題 -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bx bx-dollar-circle text-primary me-2"></i>金流與付款紀錄
        </h4>
        <div>
            <span class="badge bg-label-info">
                <i class="bx bx-list-ul me-1"></i>共 @Model.Count() 筆訂單
            </span>
        </div>
    </div>

    <!-- 金流紀錄卡片 -->
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bx bx-credit-card me-2"></i>付款交易紀錄
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 8%;">訂單編號</th>
                            <th style="width: 15%;">綠界交易序號</th>
                            <th class="text-center" style="width: 10%;">付款方式</th>
                            <th class="text-end" style="width: 12%;">付款金額</th>
                            <th class="text-center" style="width: 10%;">付款狀態</th>
                            <th class="text-center" style="width: 15%;">付款時間</th>
                            <th class="text-center" style="width: 15%;">訂單建立時間</th>
                            <th class="text-center" style="width: 10%;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var order in Model)
                            {
                                // 取得第一筆付款紀錄（如果有）
                                var payment = order.PaymentLogs?.FirstOrDefault();
                                
                                // 判斷付款狀態
                                string statusBadgeClass = "bg-label-warning";
                                string statusText = "未付款";
                                
                                if (order.Status == 1 || (payment != null && payment.RtnCode == 1))
                                {
                                    statusBadgeClass = "bg-label-success";
                                    statusText = "已付款";
                                }
                                else if (order.Status == 0)
                                {
                                    statusBadgeClass = "bg-label-warning";
                                    statusText = "待付款";
                                }
                                else if (order.Status == 4)
                                {
                                    statusBadgeClass = "bg-label-danger";
                                    statusText = "已取消";
                                }

                                <tr>
                                    <!-- 訂單編號 -->
                                    <td class="text-center">
                                        <span class="fw-semibold text-primary">
                                            #@order.OrderNumber
                                        </span>
                                    </td>

                                    <!-- 綠界交易序號 -->
                                    <td>
                                        @if (payment != null && !string.IsNullOrEmpty(payment.TradeNo))
                                        {
                                            <small class="text-muted d-block">
                                                <i class="bx bx-barcode me-1"></i>@payment.TradeNo
                                            </small>
                                            @if (!string.IsNullOrEmpty(payment.MerchantTradeNo))
                                            {
                                                <small class="text-muted d-block mt-1">
                                                    商店訂單號: @payment.MerchantTradeNo
                                                </small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <!-- 付款方式 -->
                                    <td class="text-center">
                                        @if (payment != null && !string.IsNullOrEmpty(payment.PaymentType))
                                        {
                                            var paymentIcon = payment.PaymentType switch
                                            {
                                                "Credit" or "信用卡" => "bx-credit-card",
                                                "ATM" or "ATM轉帳" => "bx-bank",
                                                "CVS" or "超商代碼" => "bx-store",
                                                _ => "bx-wallet"
                                            };
                                            var paymentLabel = payment.PaymentType switch
                                            {
                                                "Credit" => "信用卡",
                                                "ATM" => "ATM轉帳",
                                                "CVS" => "超商代碼",
                                                _ => payment.PaymentType
                                            };
                                            <i class="bx @paymentIcon me-1"></i>
                                            <span>@paymentLabel</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <!-- 付款金額 -->
                                    <td class="text-end">
                                        <span class="fw-bold text-dark" style="font-size: 1.05rem;">
                                            $ @order.FinalAmount.ToString("N0")
                                        </span>
                                        @if (order.DiscountAmount > 0 || order.PointDiscount > 0)
                                        {
                                            <br />
                                            <small class="text-success">
                                                <i class="bx bx-down-arrow-circle"></i>
                                                折扣 $@((order.DiscountAmount ?? 0) + (order.PointDiscount ?? 0))
                                            </small>
                                        }
                                    </td>

                                    <!-- 付款狀態 -->
                                    <td class="text-center">
                                        <span class="badge @statusBadgeClass">
                                            @statusText
                                        </span>
                                        @if (payment?.RtnMsg != null && payment.RtnCode != 1)
                                        {
                                            <br />
                                            <small class="text-danger mt-1" style="font-size: 0.7rem;">
                                                @payment.RtnMsg
                                            </small>
                                        }
                                    </td>

                                    <!-- 付款時間 -->
                                    <td class="text-center">
                                        @if (order.PaymentDate.HasValue)
                                        {
                                            <span>@order.PaymentDate.Value.ToString("yyyy/MM/dd")</span>
                                            <br />
                                            <small class="text-muted">@order.PaymentDate.Value.ToString("HH:mm:ss")</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <!-- 訂單建立時間 -->
                                    <td class="text-center">
                                        @if (order.CreatedAt.HasValue)
                                        {
                                            <span>@order.CreatedAt.Value.ToString("yyyy/MM/dd")</span>
                                            <br />
                                            <small class="text-muted">@order.CreatedAt.Value.ToString("HH:mm:ss")</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <!-- 操作 -->
                                    <td class="text-center">
                                        <div class="dropdown">
                                            <button type="button" class="btn btn-sm btn-icon btn-text-secondary rounded-pill dropdown-toggle hide-arrow" 
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bx bx-dots-vertical-rounded"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" href="@Url.Action("Details", "Orders", new { area = "Admin", id = order.Id })">
                                                        <i class="bx bx-show me-2"></i>查看訂單明細
                                                    </a>
                                                </li>
                                                @if (payment != null)
                                                {
                                                    <li>
                                                        <a class="dropdown-item" href="javascript:void(0);" 
                                                           onclick="showPaymentDetails(@order.Id, '@payment.TradeNo')">
                                                            <i class="bx bx-receipt me-2"></i>查看金流紀錄
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bx bx-info-circle fs-1 mb-2 d-block"></i>
                                        <p class="mb-0">目前沒有任何金流紀錄</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="card-footer bg-light border-top">
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                        <i class="bx bx-time-five me-1"></i>最後更新：@DateTime.Now.ToString("yyyy/MM/dd HH:mm")
                    </small>
                    <small class="text-muted">
                        共 @Model.Count() 筆紀錄
                    </small>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function showPaymentDetails(orderId, tradeNo) {
            // 顯示金流明細的 Modal 或導向詳細頁面
            showAlert('金流明細功能\n\n訂單 ID: ' + orderId + '\n交易序號: ' + tradeNo + '\n\n此功能可在未來擴充顯示完整的綠界回傳參數。');
        }

        // 表格列 hover 效果優化
        document.querySelectorAll('.table-hover tbody tr').forEach(function(row) {
            row.style.cursor = 'pointer';
        });
    </script>
}
